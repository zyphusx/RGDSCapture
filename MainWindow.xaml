<Window x:Class="RGDSCapture.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RGDSCapture"
        Height="820" Width="1040"
        MinHeight="620" MinWidth="760"
        Background="{DynamicResource WindowBg}"
        WindowStartupLocation="CenterScreen"
        KeyDown="MainWindow_KeyDown"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>

        <!-- ── Focus ring used by all interactive controls ── -->
        <Style x:Key="FocusRingStyle" TargetType="Control">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Standard button ── -->
        <Style TargetType="Button" x:Key="Btn">
            <Setter Property="Background"      Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource BtnFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="Margin"          Value="3,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource BtnPress}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource FocusRing}"/>
                                <Setter TargetName="Root" Property="BorderThickness"
                                        Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent / Connect button ── -->
        <Style TargetType="Button" x:Key="BtnAccent" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="{DynamicResource BtnConnectBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnConnectBorder}"/>
            <Setter Property="Foreground"  Value="{DynamicResource BtnConnectFg}"/>
            <Setter Property="Width"       Value="110"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource AccentPress}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource FocusRing}"/>
                                <Setter TargetName="Root" Property="BorderThickness"
                                        Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger button ── -->
        <Style TargetType="Button" x:Key="BtnDanger" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="{DynamicResource BtnDangerBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnDangerBorder}"/>
            <Setter Property="Foreground"  Value="{DynamicResource BtnDangerFg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource BtnDangerHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource BtnPress}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource FocusRing}"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox" x:Key="TBox">
            <Setter Property="Background"               Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource InputFg}"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource InputCaret}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="10,7"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="SnapsToDevicePixels"      Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource InputBorderFocus}"/>
                                <Setter TargetName="Root" Property="BorderThickness"
                                        Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox with proper text rendering ── -->
        <Style TargetType="ComboBox" x:Key="CBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="templateRoot" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Background" 
                                    Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     FontSize="{TemplateBinding FontSize}"
                                     FontFamily="{TemplateBinding FontFamily}"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     TextOptions.TextFormattingMode="Display"
                                     TextOptions.TextRenderingMode="ClearType"/>
                            <ToggleButton x:Name="toggleButton"
                                          Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Padding="8,0"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <TextBlock Text="▼" Foreground="{TemplateBinding Foreground}" 
                                                       FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Grid.ColumnSpan="2"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}"
                                   Placement="Bottom">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource InputBg}"
                                        BorderBrush="{DynamicResource InputBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,4,0,0">
                                    <ScrollViewer x:Name="DropDownScrollViewer">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Background" Property="BorderBrush"
                                        Value="{DynamicResource InputBorderFocus}"/>
                                <Setter TargetName="Background" Property="BorderThickness"
                                        Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource InputFg}"/>
                        <Setter Property="Background" Value="{DynamicResource InputBg}"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextOptions.TextFormattingMode="Display"
                                                          TextOptions.TextRenderingMode="ClearType"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BtnHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BtnPress}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dim label ── -->
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="Foreground"        Value="{DynamicResource LabelFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Margin"            Value="6,0"/>
        </Style>

        <!-- ── Toolbar surface ── -->
        <Style TargetType="Border" x:Key="ToolbarSurface">
            <Setter Property="Background"      Value="{DynamicResource ToolbarBg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ToolbarBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="12,8"/>
        </Style>

        <!-- ── Section label (small caps above groups) ── -->
        <Style TargetType="TextBlock" x:Key="SectionLbl">
            <Setter Property="Foreground"        Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="6,0,4,0"/>
        </Style>

        <!-- ── Menu Item Text Rendering ── -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource MenuFg}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- ══════════════════════════════════════════════════════════
             MENU BAR
        ══════════════════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource MenuBg}"
              Foreground="{DynamicResource MenuFg}"
              BorderBrush="{DynamicResource MenuBorder}"
              BorderThickness="0,0,0,1"
              Padding="4,2"
              FontSize="13">

            <!-- File -->
            <MenuItem Header="_File" Foreground="{DynamicResource MenuFg}">
                <MenuItem x:Name="MnuConnect"    Header="_Connect"    Click="BtnConnect_Click"
                          InputGestureText="" Foreground="{DynamicResource MenuFg}"/>
                <MenuItem x:Name="MnuDisconnect" Header="_Disconnect" Click="MnuDisconnect_Click"
                          IsEnabled="False" Foreground="{DynamicResource MenuFg}"/>
                <Separator/>
                <MenuItem Header="_Screenshot"   Click="BtnScreenshot_Click"
                          InputGestureText="F12" IsEnabled="False" x:Name="MnuScreenshot" Foreground="{DynamicResource MenuFg}"/>
                <Separator/>
                <MenuItem Header="E_xit"         Click="MnuExit_Click"
                          InputGestureText="Alt+F4" Foreground="{DynamicResource MenuFg}"/>
            </MenuItem>

            <!-- Streams -->
            <MenuItem Header="_Streams" Foreground="{DynamicResource MenuFg}">
                <MenuItem x:Name="MnuRestartTop"    Header="Restart _Top Screen"
                          Click="BtnRestartTop_Click"    IsEnabled="False"
                          InputGestureText="F6" Foreground="{DynamicResource MenuFg}"/>
                <MenuItem x:Name="MnuRestartBottom" Header="Restart _Bottom Screen"
                          Click="BtnRestartBottom_Click" IsEnabled="False"
                          InputGestureText="F7" Foreground="{DynamicResource MenuFg}"/>
                <MenuItem x:Name="MnuRestartAll"    Header="Restart _All"
                          Click="BtnRestartAll_Click"    IsEnabled="False"
                          InputGestureText="F5" Foreground="{DynamicResource MenuFg}"/>
                <Separator/>
                <MenuItem x:Name="MnuRecordTop"    Header="Record Top to MP4"
                          Click="BtnRecordTop_Click"    IsEnabled="False" Foreground="{DynamicResource MenuFg}"/>
                <MenuItem x:Name="MnuRecordBottom" Header="Record Bottom to MP4"
                          Click="BtnRecordBottom_Click" IsEnabled="False" Foreground="{DynamicResource MenuFg}"/>
            </MenuItem>

            <!-- Console -->
            <MenuItem Header="_Console" Foreground="{DynamicResource MenuFg}">
                <MenuItem x:Name="MnuShutdown" Header="_Shutdown Console"
                          Click="BtnShutdown_Click" IsEnabled="False" Foreground="{DynamicResource MenuFg}"/>
                <MenuItem x:Name="MnuReboot"   Header="_Reboot Console"
                          Click="BtnReboot_Click"   IsEnabled="False" Foreground="{DynamicResource MenuFg}"/>
            </MenuItem>

            <!-- View -->
            <MenuItem Header="_View" Foreground="{DynamicResource MenuFg}">
                <MenuItem Header="_Layout" Foreground="{DynamicResource MenuFg}">
                    <MenuItem x:Name="MnuLayoutVertical"   Header="_Vertical Stack"
                              IsCheckable="True"
                              Click="MnuLayout_Click" Tag="0" Foreground="{DynamicResource MenuFg}"/>
                    <MenuItem x:Name="MnuLayoutSide"       Header="_Side by Side"
                              IsCheckable="True" IsChecked="True"
                              Click="MnuLayout_Click" Tag="1" Foreground="{DynamicResource MenuFg}"/>
                    <MenuItem x:Name="MnuLayoutTopOnly"    Header="Top _Only"
                              IsCheckable="True"
                              Click="MnuLayout_Click" Tag="2" Foreground="{DynamicResource MenuFg}"/>
                    <MenuItem x:Name="MnuLayoutBottomOnly" Header="_Bottom Only"
                              IsCheckable="True"
                              Click="MnuLayout_Click" Tag="3" Foreground="{DynamicResource MenuFg}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Theme" Foreground="{DynamicResource MenuFg}">
                    <MenuItem x:Name="MnuThemeDark"    Header="_Dark"
                              IsCheckable="True" IsChecked="True"
                              Click="MnuTheme_Click" Tag="Dark" Foreground="{DynamicResource MenuFg}"/>
                    <MenuItem x:Name="MnuThemeLight"   Header="_Light"
                              IsCheckable="True"
                              Click="MnuTheme_Click" Tag="Light" Foreground="{DynamicResource MenuFg}"/>
                    <MenuItem x:Name="MnuThemeHCD"     Header="High Contrast _Dark"
                              IsCheckable="True"
                              Click="MnuTheme_Click" Tag="HighContrastDark" Foreground="{DynamicResource MenuFg}"/>
                    <MenuItem x:Name="MnuThemeHCL"     Header="High Contrast _Light"
                              IsCheckable="True"
                              Click="MnuTheme_Click" Tag="HighContrastLight" Foreground="{DynamicResource MenuFg}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Toggle Event _Log" Click="BtnToggleLog_Click"
                          InputGestureText="F8" Foreground="{DynamicResource MenuFg}"/>
            </MenuItem>

        </Menu>

        <!-- ══════════════════════════════════════════════════════════
             TOOLBAR 1 — Connection
        ══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Style="{StaticResource ToolbarSurface}">
            <WrapPanel VerticalAlignment="Center" Margin="0">

                <!-- IP + Port -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <TextBlock Text="Device IP" Style="{StaticResource SectionLbl}"
                               ToolTip="IP address of your RG DS"/>
                    <TextBox x:Name="TxtIpAddress" Style="{StaticResource TBox}"
                             Width="148" Text="192.168.1.100"
                             AutomationProperties.Name="Device IP Address"
                             ToolTip="IP address of your RG DS"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="Port" Style="{StaticResource SectionLbl}"
                               ToolTip="SSH port (usually 22)"/>
                    <TextBox x:Name="TxtSshPort" Style="{StaticResource TBox}"
                             Width="90" Text="22"
                             AutomationProperties.Name="SSH Port"
                             ToolTip="SSH port (usually 22)"/>
                </StackPanel>

                <Button x:Name="BtnConnect" Content="Connect"
                        Style="{StaticResource BtnAccent}"
                        Margin="0,0,12,0"
                        Click="BtnConnect_Click"
                        AutomationProperties.Name="Connect to device"
                        ToolTip="SSH into RG DS and start streams"/>

                <!-- Separator -->
                <Separator Width="1" Height="24"
                           Background="{DynamicResource SeparatorBg}"
                           Margin="0,0,12,0" VerticalAlignment="Center"/>

                <!-- Screenshot -->
                <Button x:Name="BtnScreenshot" Content="📷  Screenshot"
                        Style="{StaticResource Btn}" IsEnabled="False"
                        Click="BtnScreenshot_Click"
                        AutomationProperties.Name="Take screenshot"
                        ToolTip="Save PNG of both screens  (F12)"/>

                <!-- Log toggle -->
                <Button x:Name="BtnToggleLog" Content="📋  Log"
                        Style="{StaticResource Btn}"
                        Click="BtnToggleLog_Click"
                        AutomationProperties.Name="Toggle event log"
                        ToolTip="Show / hide event log  (F8)"/>

            </WrapPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             TOOLBAR 2 — Streams + Record + Power
        ══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Style="{StaticResource ToolbarSurface}">
            <WrapPanel VerticalAlignment="Center">

                <TextBlock Text="Streams" Style="{StaticResource SectionLbl}"/>
                <Button x:Name="BtnRestartTop" Content="↺  Top"
                        Style="{StaticResource Btn}" IsEnabled="False"
                        Click="BtnRestartTop_Click"
                        AutomationProperties.Name="Restart top stream"
                        ToolTip="Restart top screen stream  (F6)"/>
                <Button x:Name="BtnRestartBottom" Content="↺  Bottom"
                        Style="{StaticResource Btn}" IsEnabled="False"
                        Click="BtnRestartBottom_Click"
                        AutomationProperties.Name="Restart bottom stream"
                        ToolTip="Restart bottom screen stream  (F7)"/>
                <Button x:Name="BtnRestartAll" Content="↺  All"
                        Style="{StaticResource Btn}" IsEnabled="False"
                        Click="BtnRestartAll_Click"
                        AutomationProperties.Name="Restart all streams"
                        ToolTip="Restart all streams  (F5)"/>

                <Separator Width="1" Height="24"
                           Background="{DynamicResource SeparatorBg}"
                           Margin="8,0" VerticalAlignment="Center"/>

                <TextBlock Text="Record" Style="{StaticResource SectionLbl}"/>
                <Button x:Name="BtnRecordTop" Content="⏺  Top"
                        Style="{StaticResource Btn}" IsEnabled="False"
                        Click="BtnRecordTop_Click"
                        AutomationProperties.Name="Record top screen"
                        ToolTip="Record top screen to MP4"/>
                <Button x:Name="BtnRecordBottom" Content="⏺  Bottom"
                        Style="{StaticResource Btn}" IsEnabled="False"
                        Click="BtnRecordBottom_Click"
                        AutomationProperties.Name="Record bottom screen"
                        ToolTip="Record bottom screen to MP4"/>

                <Separator Width="1" Height="24"
                           Background="{DynamicResource SeparatorBg}"
                           Margin="8,0" VerticalAlignment="Center"/>

                <TextBlock Text="Console" Style="{StaticResource SectionLbl}"/>
                <Button x:Name="BtnShutdown" Content="⏻  Shutdown"
                        Style="{StaticResource BtnDanger}" IsEnabled="False"
                        Click="BtnShutdown_Click"
                        AutomationProperties.Name="Shutdown console"
                        ToolTip="Send shutdown command to console"/>
                <Button x:Name="BtnReboot" Content="↻  Reboot"
                        Style="{StaticResource BtnDanger}" IsEnabled="False"
                        Click="BtnReboot_Click"
                        AutomationProperties.Name="Reboot console"
                        ToolTip="Send reboot command to console"/>

            </WrapPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             TOOLBAR 3 — Audio + Speedrun Timer
        ══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Style="{StaticResource ToolbarSurface}">
            <WrapPanel VerticalAlignment="Center">

                <TextBlock Text="🔊" FontSize="15"
                           Foreground="{DynamicResource LabelFg}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>

                <ComboBox x:Name="CmbAudioInput" Style="{StaticResource CBox}"
                          Width="220"
                          AutomationProperties.Name="Audio input device"
                          ToolTip="Select Line-In / audio input device"/>

                <TextBlock Text="→" Style="{StaticResource SectionLbl}"/>

                <ComboBox x:Name="CmbAudioOutput" Style="{StaticResource CBox}"
                          Width="200"
                          AutomationProperties.Name="Audio output device"
                          ToolTip="Select audio output"/>

                <Button x:Name="BtnAudioStart" Content="▶  Audio"
                        Style="{StaticResource Btn}"
                        Margin="8,0,0,0"
                        Click="BtnAudioStart_Click"
                        AutomationProperties.Name="Start audio passthrough"
                        ToolTip="Start Line-In audio passthrough"/>

                <!-- Volume -->
                <TextBlock Text="Vol" Style="{StaticResource SectionLbl}" Margin="10,0,4,0"/>
                <Slider x:Name="SliderVolume"
                        Width="84" Minimum="0" Maximum="1" Value="0.85"
                        VerticalAlignment="Center"
                        ValueChanged="SliderVolume_ValueChanged"
                        AutomationProperties.Name="Volume"
                        ToolTip="Output volume"/>
                <TextBlock x:Name="TxtVolumeLabel" Text="85%"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center" Width="34"
                           FontSize="12" Margin="4,0,0,0"/>

                <!-- VU meters -->
                <Border Width="6" Height="20"
                        Background="{DynamicResource VuBg}"
                        BorderBrush="{DynamicResource VuBorder}"
                        BorderThickness="1" CornerRadius="2"
                        Margin="8,0,2,0"
                        ToolTip="Left channel level"
                        AutomationProperties.Name="Left channel level">
                    <Grid>
                        <Rectangle x:Name="VuLeft" Fill="#0078D4"
                                   HorizontalAlignment="Left" Width="0"
                                   RadiusX="2" RadiusY="2"/>
                    </Grid>
                </Border>
                <Border Width="6" Height="20"
                        Background="{DynamicResource VuBg}"
                        BorderBrush="{DynamicResource VuBorder}"
                        BorderThickness="1" CornerRadius="2"
                        Margin="0,0,10,0"
                        ToolTip="Right channel level"
                        AutomationProperties.Name="Right channel level">
                    <Grid>
                        <Rectangle x:Name="VuRight" Fill="#0078D4"
                                   HorizontalAlignment="Left" Width="0"
                                   RadiusX="2" RadiusY="2"/>
                    </Grid>
                </Border>

                <Separator Width="1" Height="24"
                           Background="{DynamicResource SeparatorBg}"
                           Margin="0,0,10,0" VerticalAlignment="Center"/>

                <!-- Speedrun timer -->
                <TextBlock Text="⏱" FontSize="15"
                           Foreground="{DynamicResource LabelFg}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Border Background="{DynamicResource TimerBg}"
                        BorderBrush="{DynamicResource TimerBorder}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,4" Margin="0,0,6,0">
                    <TextBlock x:Name="TxtSpeedrunTimer"
                               Text="00:00.000"
                               Foreground="{DynamicResource TimerFg}"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Speedrun timer"/>
                </Border>

                <Button x:Name="BtnTimerStartStop" Content="▶  Start"
                        Style="{StaticResource Btn}"
                        Click="BtnTimerStartStop_Click"
                        AutomationProperties.Name="Start or pause timer"
                        ToolTip="Start / pause timer  (Space)"/>
                <Button x:Name="BtnTimerLap" Content="⚑  Lap"
                        Style="{StaticResource Btn}"
                        Click="BtnTimerLap_Click"
                        AutomationProperties.Name="Record lap"
                        ToolTip="Record lap split to log"/>
                <Button x:Name="BtnTimerReset" Content="✕  Reset"
                        Style="{StaticResource Btn}"
                        Click="BtnTimerReset_Click"
                        AutomationProperties.Name="Reset timer"
                        ToolTip="Reset timer to zero"/>

            </WrapPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             STATUS BAR
        ══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource StatusBarBg}"
                BorderBrush="{DynamicResource StatusBarBorder}"
                BorderThickness="0,1,0,0"
                Padding="14,5">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="8" Height="8"
                             Fill="{DynamicResource StatusDotOff}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="Not connected"
                               Foreground="{DynamicResource StatusFg}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Keyboard shortcut hint on the right -->
                <TextBlock DockPanel.Dock="Right"
                           Foreground="{DynamicResource TextDisabled}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Text="F5 Restart All  ·  F6 Top  ·  F7 Bottom  ·  F8 Log  ·  F12 Screenshot  ·  Space Timer"/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             MAIN CONTENT — full-width video + overlay log drawer
        ══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="ContentGrid" ClipToBounds="True">

            <!-- ── VIDEO AREA ── -->
            <Grid x:Name="VideoGrid" Background="{DynamicResource VideoAreaBg}">

                <!-- VERTICAL STACK (default) -->
                <Grid x:Name="LayoutVertical" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource ScreenBg}"
                            BorderBrush="{DynamicResource ScreenBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="10,10,10,0">
                        <Grid>
                            <TextBlock Text="TOP SCREEN"
                                       Foreground="{DynamicResource ScreenLabelFg}"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="Top screen display"/>
                            <Image x:Name="ImgTopScreen" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   AutomationProperties.Name="Top screen video"/>
                            <!-- Fullscreen button -->
                            <Button Content="⛶"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    Padding="6,3"
                                    FontSize="14"
                                    Opacity="0.75"
                                    Background="#AA000000"
                                    Foreground="#FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Panel.ZIndex="5"
                                    Click="BtnFullscreenTop_Click"
                                    ToolTip="Full screen — Top Screen  (F2)"
                                    AutomationProperties.Name="Full screen top screen">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10,6">
                                <Ellipse x:Name="DotTop" Width="8" Height="8"
                                         Fill="{DynamicResource BadgeWaiting}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TxtTopBadge" Text="○ WAITING"
                                           Foreground="{DynamicResource BadgeWaiting}"
                                           FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtTopFps" Text="-- fps"
                                           Foreground="{DynamicResource FpsFg}"
                                           FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource ScreenDivider}"/>

                    <Border Grid.Row="2"
                            Background="{DynamicResource ScreenBg}"
                            BorderBrush="{DynamicResource ScreenBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="10,0,10,10">
                        <Grid>
                            <TextBlock Text="BOTTOM SCREEN"
                                       Foreground="{DynamicResource ScreenLabelFg}"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       AutomationProperties.Name="Bottom screen display"/>
                            <Image x:Name="ImgBottomScreen" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   AutomationProperties.Name="Bottom screen video"/>
                            <!-- Fullscreen button -->
                            <Button Content="⛶"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    Padding="6,3"
                                    FontSize="14"
                                    Opacity="0.75"
                                    Background="#AA000000"
                                    Foreground="#FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Panel.ZIndex="5"
                                    Click="BtnFullscreenBottom_Click"
                                    ToolTip="Full screen — Bottom Screen  (F3)"
                                    AutomationProperties.Name="Full screen bottom screen">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10,6">
                                <Ellipse x:Name="DotBottom" Width="8" Height="8"
                                         Fill="{DynamicResource BadgeWaiting}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TxtBottomBadge" Text="○ WAITING"
                                           Foreground="{DynamicResource BadgeWaiting}"
                                           FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtBottomFps" Text="-- fps"
                                           Foreground="{DynamicResource FpsFg}"
                                           FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- SIDE BY SIDE -->
                <Grid x:Name="LayoutSideBySide" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource ScreenBg}"
                            BorderBrush="{DynamicResource ScreenBorder}"
                            BorderThickness="1" CornerRadius="8" Margin="10">
                        <Grid>
                            <TextBlock Text="TOP SCREEN"
                                       Foreground="{DynamicResource ScreenLabelFg}"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ImgTopScreenSide" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <!-- Status Indicator -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10,6">
                                <Ellipse x:Name="DotTopSide" Width="8" Height="8"
                                         Fill="{DynamicResource BadgeWaiting}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TxtTopBadgeSide" Text="○ WAITING"
                                           Foreground="{DynamicResource BadgeWaiting}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                            <!-- FPS Overlay -->
                            <Border Background="{DynamicResource ScreenBg}" 
                                    CornerRadius="4"
                                    Opacity="0.7"
                                    Padding="6,3"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    Margin="0,6,6,0">
                                <TextBlock x:Name="TxtTopFpsValueSide" Text="0.0 FPS"
                                           Foreground="{DynamicResource ScreenLabelFg}"
                                           FontFamily="Consolas, monospace"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <!-- Fullscreen button -->
                            <Button Content="⛶"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,32,6,0"
                                    Padding="6,3"
                                    FontSize="14"
                                    Opacity="0.75"
                                    Background="#AA000000"
                                    Foreground="#FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Panel.ZIndex="5"
                                    Click="BtnFullscreenTop_Click"
                                    ToolTip="Full screen — Top Screen  (F2)"
                                    AutomationProperties.Name="Full screen top screen">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource ScreenDivider}"/>
                    <Border Grid.Column="2" Background="{DynamicResource ScreenBg}"
                            BorderBrush="{DynamicResource ScreenBorder}"
                            BorderThickness="1" CornerRadius="8" Margin="10">
                        <Grid>
                            <TextBlock Text="BOTTOM SCREEN"
                                       Foreground="{DynamicResource ScreenLabelFg}"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ImgBottomScreenSide" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <!-- Status Indicator -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10,6">
                                <Ellipse x:Name="DotBottomSide" Width="8" Height="8"
                                         Fill="{DynamicResource BadgeWaiting}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TxtBottomBadgeSide" Text="○ WAITING"
                                           Foreground="{DynamicResource BadgeWaiting}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                            <!-- FPS Overlay -->
                            <Border Background="{DynamicResource ScreenBg}" 
                                    CornerRadius="4"
                                    Opacity="0.7"
                                    Padding="6,3"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    Margin="0,6,6,0">
                                <TextBlock x:Name="TxtBottomFpsValueSide" Text="0.0 FPS"
                                           Foreground="{DynamicResource ScreenLabelFg}"
                                           FontFamily="Consolas, monospace"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <!-- Fullscreen button -->
                            <Button Content="⛶"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,32,6,0"
                                    Padding="6,3"
                                    FontSize="14"
                                    Opacity="0.75"
                                    Background="#AA000000"
                                    Foreground="#FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Panel.ZIndex="5"
                                    Click="BtnFullscreenBottom_Click"
                                    ToolTip="Full screen — Bottom Screen  (F3)"
                                    AutomationProperties.Name="Full screen bottom screen">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- TOP ONLY -->
                <Grid x:Name="LayoutTopOnly" Visibility="Collapsed">
                    <Border Background="{DynamicResource ScreenBg}"
                            BorderBrush="{DynamicResource ScreenBorder}"
                            BorderThickness="1" CornerRadius="8" Margin="10">
                        <Grid>
                            <TextBlock Text="TOP SCREEN"
                                       Foreground="{DynamicResource ScreenLabelFg}"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ImgTopScreenOnly" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <!-- Status Indicator -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10,6">
                                <Ellipse x:Name="DotTopOnly" Width="8" Height="8"
                                         Fill="{DynamicResource BadgeWaiting}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TxtTopBadgeOnly" Text="○ WAITING"
                                           Foreground="{DynamicResource BadgeWaiting}"
                                           FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtTopFpsOnly" Text="-- fps"
                                           Foreground="{DynamicResource FpsFg}"
                                           FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>
                            <!-- Fullscreen button -->
                            <Button Content="⛶"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    Padding="6,3"
                                    FontSize="14"
                                    Opacity="0.75"
                                    Background="#AA000000"
                                    Foreground="#FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Panel.ZIndex="5"
                                    Click="BtnFullscreenTop_Click"
                                    ToolTip="Full screen — Top Screen  (F2)"
                                    AutomationProperties.Name="Full screen top screen">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- BOTTOM ONLY -->
                <Grid x:Name="LayoutBottomOnly" Visibility="Collapsed">
                    <Border Background="{DynamicResource ScreenBg}"
                            BorderBrush="{DynamicResource ScreenBorder}"
                            BorderThickness="1" CornerRadius="8" Margin="10">
                        <Grid>
                            <TextBlock Text="BOTTOM SCREEN"
                                       Foreground="{DynamicResource ScreenLabelFg}"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ImgBottomScreenOnly" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <!-- Status Indicator -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="10,6">
                                <Ellipse x:Name="DotBottomOnly" Width="8" Height="8"
                                         Fill="{DynamicResource BadgeWaiting}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TxtBottomBadgeOnly" Text="○ WAITING"
                                           Foreground="{DynamicResource BadgeWaiting}"
                                           FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtBottomFpsOnly" Text="-- fps"
                                           Foreground="{DynamicResource FpsFg}"
                                           FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>
                            <!-- Fullscreen button -->
                            <Button Content="⛶"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    Padding="6,3"
                                    FontSize="14"
                                    Opacity="0.75"
                                    Background="#AA000000"
                                    Foreground="#FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Panel.ZIndex="5"
                                    Click="BtnFullscreenBottom_Click"
                                    ToolTip="Full screen — Bottom Screen  (F3)"
                                    AutomationProperties.Name="Full screen bottom screen">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- ── SLIDE-OUT LOG DRAWER ── -->
            <Border x:Name="LogDrawer"
                    Width="270"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource SidePanelBg}"
                    BorderBrush="{DynamicResource SidePanelBorder}"
                    BorderThickness="1,0,0,0"
                    Panel.ZIndex="10"
                    AutomationProperties.Name="Event log drawer">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="DrawerTranslate" X="270"/>
                </Border.RenderTransform>
                <DockPanel>

                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource LogHeaderBg}"
                            BorderBrush="{DynamicResource SidePanelBorder}"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="✕"
                                    Style="{StaticResource Btn}"
                                    Padding="8,4" Margin="0"
                                    Click="BtnToggleLog_Click"
                                    AutomationProperties.Name="Close log"
                                    ToolTip="Close log  (F8)"/>
                            <TextBlock Text="Event Log"
                                       Foreground="{DynamicResource LogHeaderFg}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Button DockPanel.Dock="Bottom"
                            Content="Clear Log"
                            Style="{StaticResource Btn}"
                            Margin="8"
                            Click="BtnClearLog_Click"
                            AutomationProperties.Name="Clear event log"/>

                    <TextBox x:Name="TxtEventLog"
                             Background="{DynamicResource LogBg}"
                             Foreground="{DynamicResource LogFg}"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="11"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             AcceptsReturn="True"
                             AutomationProperties.Name="Event log output"
                             AutomationProperties.LiveSetting="Polite"/>
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
