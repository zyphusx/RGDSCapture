<Window x:Class="RGDSCapture.ConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to RG DS"
        Height="240" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a2e"
        ShowInTaskbar="False">

    <StackPanel Margin="24">

        <TextBlock Text="SSH Credentials"
                   Foreground="#e0e0e0"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <TextBlock Text="Username" Foreground="#a0a0b0" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtUsername"
                 Background="#16213e" Foreground="#e0e0e0"
                 BorderBrush="#0f3460" BorderThickness="1"
                 Padding="8,6" Margin="0,0,0,12"
                 CaretBrush="#e0e0e0"
                 Text="root"/>

        <TextBlock Text="Password" Foreground="#a0a0b0" FontSize="12" Margin="0,0,0,4"/>
        <PasswordBox x:Name="TxtPassword"
                     Background="#16213e" Foreground="#e0e0e0"
                     BorderBrush="#0f3460" BorderThickness="1"
                     Padding="8,6" Margin="0,0,0,20"
                     CaretBrush="#e0e0e0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="80" Padding="0,6"
                    Background="#16213e" Foreground="#e0e0e0"
                    BorderBrush="#0f3460" BorderThickness="1"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Connect"
                    Width="80" Padding="0,6"
                    Background="#0f3460" Foreground="#e0e0e0"
                    BorderBrush="#0f3460" BorderThickness="1"
                    IsDefault="True"
                    Click="BtnConnect_Click"/>
        </StackPanel>

    </StackPanel>
</Window>