<Window x:Class="RGDSCapture.Views.ConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to RG DS"
        Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBg}"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <StackPanel Margin="24">

        <TextBlock Text="SSH Credentials"
                   Foreground="{DynamicResource TextPrimary}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <TextBlock Text="Username"
                   Foreground="{DynamicResource TextSecondary}"
                   FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtUsername" Margin="0,0,0,12"/>

        <TextBlock Text="Password"
                   Foreground="{DynamicResource TextSecondary}"
                   FontSize="12" Margin="0,0,0,4"/>
        <PasswordBox x:Name="TxtPassword" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="80"
                    IsCancel="True"
                    Margin="0,0,8,0"/>
            <Button Content="Connect"
                    Width="80"
                    Style="{StaticResource AccentButton}"
                    IsDefault="True"
                    Click="BtnConnect_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
