<Window x:Class="RGDSCapture.Views.FullScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RGDSCapture — Fullscreen"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="Black"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding Main.RestartAllCommand}"/>
        <KeyBinding Key="F6" Command="{Binding Main.RestartTopCommand}"/>
        <KeyBinding Key="F7" Command="{Binding Main.RestartBottomCommand}"/>
    </Window.InputBindings>

    <Grid Background="Black">

        <Image Source="{Binding Screen.Bitmap}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!-- Screen label, top-left -->
        <Border Background="#AA000000"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16,16,0,0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8"
                         Fill="{Binding Screen.BadgeBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,7,0"/>
                <TextBlock Text="{Binding Screen.DisplayName}"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Close button, top-right -->
        <Button Content="✕"
                Style="{StaticResource OverlayButton}"
                Width="40" Height="40"
                FontSize="18"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,16,0"
                Click="BtnClose_Click"
                AutomationProperties.Name="Close fullscreen"/>

        <!-- Hint, fades out after 3 s -->
        <TextBlock Text="ESC or double-click to exit   |   F5 / F6 / F7 restart streams"
                   Foreground="#BBC8C8C8"
                   FontSize="12"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,32">
            <TextBlock.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             BeginTime="0:0:3"
                                             Duration="0:0:0.6">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseIn"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </TextBlock.Triggers>
        </TextBlock>

    </Grid>
</Window>
