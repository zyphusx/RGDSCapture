<UserControl x:Class="RGDSCapture.Views.Controls.ScreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext: ScreenViewModel -->
    <Border Background="{DynamicResource ScreenBg}"
            BorderBrush="{DynamicResource ScreenBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="8">
        <Grid>
            <!-- Placeholder label, covered by video once frames arrive -->
            <TextBlock Text="{Binding DisplayName}"
                       Foreground="{DynamicResource ScreenLabelFg}"
                       FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <Image Source="{Binding Bitmap}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   AutomationProperties.Name="{Binding DisplayName}">
                <Image.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.FullscreenCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                </Image.InputBindings>
            </Image>

            <!-- Health badge + FPS, top-left -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="10,8">
                <Ellipse Width="8" Height="8"
                         Fill="{Binding BadgeBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,5,0"/>
                <TextBlock Text="{Binding BadgeText}"
                           Foreground="{Binding BadgeBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding FpsText}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Fullscreen button, top-right -->
            <Button Content="⛶"
                    Style="{StaticResource OverlayButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,6,6,0"
                    Panel.ZIndex="5"
                    Command="{Binding DataContext.FullscreenCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    AutomationProperties.Name="Full screen">
                <Button.ToolTip>
                    <TextBlock>
                        <Run Text="Full screen —"/>
                        <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                    </TextBlock>
                </Button.ToolTip>
            </Button>
        </Grid>
    </Border>
</UserControl>
