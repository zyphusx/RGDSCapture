<UserControl x:Class="RGDSCapture.Views.Controls.ScreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext: ScreenViewModel. Outer margin (the screen gap) is set
         on the UserControl itself by MainWindow.ApplyLayout. -->
    <Border Background="{DynamicResource ScreenBg}"
            BorderBrush="{DynamicResource ScreenBorder}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <!-- Placeholder label, covered by video once frames arrive -->
            <TextBlock Text="{Binding DisplayName}"
                       Foreground="{DynamicResource ScreenLabelFg}"
                       FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <Image Source="{Binding Bitmap}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="{Binding DataContext.ScalingMode,
                                                     RelativeSource={RelativeSource AncestorType=Window}}"
                   AutomationProperties.Name="{Binding DisplayName}">
                <Image.LayoutTransform>
                    <RotateTransform Angle="{Binding DataContext.RotationAngle,
                                             RelativeSource={RelativeSource AncestorType=Window}}"/>
                </Image.LayoutTransform>
                <Image.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.FullscreenCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                </Image.InputBindings>
            </Image>

            <!-- Health badge + FPS + optional network stats, top-left -->
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="10,8">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding BadgeBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding BadgeText}"
                               Foreground="{Binding BadgeBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FpsText}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <Border CornerRadius="3"
                        Background="#66000000"
                        Padding="6,2"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Left">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatsText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatsText}"
                               Foreground="#DDFFFFFF"
                               FontSize="11"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               AutomationProperties.Name="Network stats"/>
                </Border>
            </StackPanel>

            <!-- Recording indicator + elapsed time, top-right under ⛶ -->
            <Border CornerRadius="3"
                    Background="#66000000"
                    Padding="6,2"
                    Margin="0,40,6,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding RecText}"
                           Foreground="#FF5252"
                           FontSize="11"
                           FontWeight="Bold"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           AutomationProperties.Name="Recording indicator"/>
            </Border>

            <!-- Fullscreen button, top-right -->
            <Button Content="⛶"
                    Style="{StaticResource OverlayButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,6,6,0"
                    Panel.ZIndex="5"
                    Command="{Binding DataContext.FullscreenCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    AutomationProperties.Name="Full screen">
                <Button.ToolTip>
                    <TextBlock>
                        <Run Text="Full screen —"/>
                        <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                    </TextBlock>
                </Button.ToolTip>
            </Button>
        </Grid>
    </Border>
</UserControl>
