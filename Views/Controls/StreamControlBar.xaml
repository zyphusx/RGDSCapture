<UserControl x:Class="RGDSCapture.Views.Controls.StreamControlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DataContext: MainViewModel -->
    <UserControl.Resources>
        <Style x:Key="RecordTopButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Top.IsRecording}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RecordingBg}"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RecordBottomButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Bottom.IsRecording}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RecordingBg}"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RecordCombinedButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCombinedRecording}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RecordingBg}"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource ToolbarSurface}">
        <WrapPanel VerticalAlignment="Center">

            <TextBlock Text="Streams" Style="{StaticResource SectionLabel}"/>
            <Button Content="↺  Top"
                    Command="{Binding RestartTopCommand}"
                    Margin="0,0,4,0"
                    AutomationProperties.Name="Restart top stream"
                    ToolTip="Restart top screen stream  (F6)"/>
            <Button Content="↺  Bottom"
                    Command="{Binding RestartBottomCommand}"
                    Margin="0,0,4,0"
                    AutomationProperties.Name="Restart bottom stream"
                    ToolTip="Restart bottom screen stream  (F7)"/>
            <Button Content="↺  All"
                    Command="{Binding RestartAllCommand}"
                    AutomationProperties.Name="Restart all streams"
                    ToolTip="Restart all streams  (F5)"/>

            <Border Style="{StaticResource ToolbarSeparator}"/>

            <TextBlock Text="Record" Style="{StaticResource SectionLabel}"/>
            <Button Style="{StaticResource RecordTopButton}"
                    Content="{Binding Top.RecordButtonText}"
                    Command="{Binding Top.ToggleRecordingCommand}"
                    IsEnabled="{Binding IsConnected}"
                    Margin="0,0,4,0"
                    AutomationProperties.Name="Record top screen"
                    ToolTip="Record top screen to MP4 (no re-encoding)"/>
            <Button Style="{StaticResource RecordBottomButton}"
                    Content="{Binding Bottom.RecordButtonText}"
                    Command="{Binding Bottom.ToggleRecordingCommand}"
                    IsEnabled="{Binding IsConnected}"
                    Margin="0,0,4,0"
                    AutomationProperties.Name="Record bottom screen"
                    ToolTip="Record bottom screen to MP4 (no re-encoding)"/>
            <Button Style="{StaticResource RecordCombinedButton}"
                    Content="{Binding CombinedRecordButtonText}"
                    Command="{Binding ToggleCombinedRecordingCommand}"
                    Margin="0,0,4,0"
                    AutomationProperties.Name="Record combined"
                    ToolTip="Record both screens (stacked) + Line-In audio to one MP4"/>
            <Button Content="⏪  Replay"
                    Command="{Binding SaveReplayCommand}"
                    AutomationProperties.Name="Save instant replay"
                    ToolTip="Save the last moments of both screens to MP4  (F9)"/>

            <Border Style="{StaticResource ToolbarSeparator}"/>

            <TextBlock Text="Console" Style="{StaticResource SectionLabel}"/>
            <Button Content="⏻  Shutdown"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding ShutdownCommand}"
                    Margin="0,0,4,0"
                    AutomationProperties.Name="Shutdown console"
                    ToolTip="Send shutdown command to console"/>
            <Button Content="↻  Reboot"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding RebootCommand}"
                    AutomationProperties.Name="Reboot console"
                    ToolTip="Send reboot command to console"/>

        </WrapPanel>
    </Border>
</UserControl>
