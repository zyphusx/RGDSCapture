<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Window / chrome ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="WindowBg"          Color="#202020"/>
    <SolidColorBrush x:Key="VideoAreaBg"       Color="#1C1C1C"/>

    <!-- ── Toolbar bars ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ToolbarBg"         Color="#2B2B2B"/>
    <SolidColorBrush x:Key="ToolbarBorder"     Color="#3F3F46"/>

    <!-- ── Buttons ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BtnBg"             Color="#2D2D30"/>
    <SolidColorBrush x:Key="BtnBorder"         Color="#454545"/>
    <SolidColorBrush x:Key="BtnFg"             Color="#F0F0F0"/>
    <SolidColorBrush x:Key="BtnHover"          Color="#383838"/>
    <SolidColorBrush x:Key="BtnPress"          Color="#4A4A4A"/>

    <!-- Accent button -->
    <SolidColorBrush x:Key="BtnConnectBg"      Color="#005FB8"/>
    <SolidColorBrush x:Key="BtnConnectBorder"  Color="#0078D4"/>

    <!-- Danger button -->
    <SolidColorBrush x:Key="BtnDangerBg"       Color="#5A1D1D"/>
    <SolidColorBrush x:Key="BtnDangerBorder"   Color="#8B2E2E"/>
    <SolidColorBrush x:Key="BtnDangerFg"       Color="#FFFFFF"/>

    <!-- ── Inputs ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InputBg"           Color="#2A2A2A"/>
    <SolidColorBrush x:Key="InputFg"           Color="#F0F0F0"/>
    <SolidColorBrush x:Key="InputBorder"       Color="#505050"/>
    <SolidColorBrush x:Key="InputCaret"        Color="#FFFFFF"/>

    <!-- ── Labels / separators ───────────────────────────────────── -->
    <SolidColorBrush x:Key="LabelFg"           Color="#D0D0D0"/>
    <SolidColorBrush x:Key="SeparatorBg"       Color="#404040"/>

    <!-- ── Status bar ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="StatusBarBg"       Color="#181818"/>
    <SolidColorBrush x:Key="StatusBarBorder"   Color="#3F3F46"/>
    <SolidColorBrush x:Key="StatusFg"          Color="#C8C8C8"/>
    <SolidColorBrush x:Key="StatusDotOff"      Color="#5A5A5A"/>

    <!-- ── Video screen panels ───────────────────────────────────── -->
    <SolidColorBrush x:Key="ScreenBg"          Color="#000000"/>
    <SolidColorBrush x:Key="ScreenBorder"      Color="#404040"/>
    <SolidColorBrush x:Key="ScreenDivider"     Color="#202020"/>
    <SolidColorBrush x:Key="ScreenLabelFg"     Color="#B0B0B0"/>

    <!-- ── Stream badges ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BadgeWaiting"      Color="#606060"/>
    <SolidColorBrush x:Key="FpsFg"             Color="#A0A0A0"/>

    <!-- ── Side panel / log ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="SidePanelBg"       Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SidePanelBorder"   Color="#404040"/>
    <SolidColorBrush x:Key="LogHeaderBg"       Color="#2B2B2B"/>
    <SolidColorBrush x:Key="LogHeaderFg"       Color="#D0D0D0"/>
    <SolidColorBrush x:Key="LogBg"             Color="#181818"/>
    <SolidColorBrush x:Key="LogFg"             Color="#9CDC9C"/>

    <!-- ── Speedrun timer ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TimerBg"           Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TimerBorder"       Color="#404040"/>
    <SolidColorBrush x:Key="TimerFg"           Color="#FFD966"/>

    <!-- ── VU meter ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="VuBg"              Color="#1E1E1E"/>
    <SolidColorBrush x:Key="VuBorder"          Color="#404040"/>

</ResourceDictionary>