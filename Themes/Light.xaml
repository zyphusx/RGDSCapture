<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════
         RGDSCapture — Light theme (colors only; styles live in Controls.xaml)
         Accent: #005FB8 (Windows 11 light-mode blue)
    ════════════════════════════════════════════════════════════════ -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="WindowBg"         Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ToolbarBg"        Color="#FBFBFB"/>
    <SolidColorBrush x:Key="ToolbarBorder"    Color="#E0E0E0"/>
    <SolidColorBrush x:Key="VideoAreaBg"      Color="#E8E8E8"/>
    <SolidColorBrush x:Key="PanelBg"          Color="#FBFBFB"/>
    <SolidColorBrush x:Key="PanelBorder"      Color="#D8D8D8"/>
    <SolidColorBrush x:Key="HeaderBg"         Color="#F0F0F0"/>
    <SolidColorBrush x:Key="SeparatorBg"      Color="#D0D0D0"/>

    <!-- Typography -->
    <SolidColorBrush x:Key="TextPrimary"      Color="#1B1B1B"/>
    <SolidColorBrush x:Key="TextSecondary"    Color="#5C5C5C"/>
    <SolidColorBrush x:Key="TextDisabled"     Color="#A0A0A0"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBg"         Color="#005FB8"/>
    <SolidColorBrush x:Key="AccentHover"      Color="#1570C8"/>
    <SolidColorBrush x:Key="AccentPress"      Color="#00509C"/>
    <SolidColorBrush x:Key="AccentFg"         Color="#FFFFFF"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="BtnBg"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BtnHover"         Color="#F0F0F0"/>
    <SolidColorBrush x:Key="BtnPress"         Color="#E4E4E4"/>
    <SolidColorBrush x:Key="BtnBorder"        Color="#D0D0D0"/>
    <SolidColorBrush x:Key="BtnFg"            Color="#1B1B1B"/>
    <SolidColorBrush x:Key="DangerBg"         Color="#FDEDED"/>
    <SolidColorBrush x:Key="DangerHover"      Color="#F8DCDC"/>
    <SolidColorBrush x:Key="DangerBorder"     Color="#E8A0A0"/>
    <SolidColorBrush x:Key="DangerFg"         Color="#B42318"/>
    <SolidColorBrush x:Key="RecordingBg"      Color="#E8B4B4"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBg"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputFg"          Color="#1B1B1B"/>
    <SolidColorBrush x:Key="InputBorder"      Color="#C8C8C8"/>
    <SolidColorBrush x:Key="InputBorderFocus" Color="#005FB8"/>
    <SolidColorBrush x:Key="InputCaret"       Color="#1B1B1B"/>

    <!-- Menus -->
    <SolidColorBrush x:Key="MenuBg"           Color="#FBFBFB"/>
    <SolidColorBrush x:Key="MenuFg"           Color="#1B1B1B"/>
    <SolidColorBrush x:Key="MenuBorder"       Color="#E0E0E0"/>
    <SolidColorBrush x:Key="MenuPopupBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MenuHoverBg"      Color="#EAEAEA"/>
    <SolidColorBrush x:Key="MenuSeparator"    Color="#E0E0E0"/>

    <!-- Status bar -->
    <SolidColorBrush x:Key="StatusBarBg"      Color="#FBFBFB"/>
    <SolidColorBrush x:Key="StatusBarBorder"  Color="#E0E0E0"/>
    <SolidColorBrush x:Key="StatusFg"         Color="#5C5C5C"/>
    <SolidColorBrush x:Key="StatusErrorFg"    Color="#B42318"/>

    <!-- Video panels -->
    <SolidColorBrush x:Key="ScreenBg"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ScreenBorder"     Color="#C8C8C8"/>
    <SolidColorBrush x:Key="ScreenLabelFg"    Color="#4A4A4A"/>

    <!-- Log drawer -->
    <SolidColorBrush x:Key="LogBg"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LogFg"            Color="#107C10"/>
    <SolidColorBrush x:Key="LogErrorFg"       Color="#B42318"/>
    <SolidColorBrush x:Key="LogTimestampFg"   Color="#9A9A9A"/>

    <!-- Speedrun timer -->
    <SolidColorBrush x:Key="TimerBg"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TimerBorder"      Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TimerFg"          Color="#9A6700"/>

    <!-- VU meter -->
    <SolidColorBrush x:Key="VuBg"             Color="#EDEDED"/>
    <SolidColorBrush x:Key="VuBorder"         Color="#C8C8C8"/>

    <!-- Misc controls -->
    <SolidColorBrush x:Key="SliderTrackBg"    Color="#C8C8C8"/>
    <SolidColorBrush x:Key="ScrollThumb"      Color="#C0C0C0"/>
    <SolidColorBrush x:Key="ScrollThumbHover" Color="#A8A8A8"/>
    <SolidColorBrush x:Key="FocusRing"        Color="#005FB8"/>
    <SolidColorBrush x:Key="TooltipBg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TooltipFg"        Color="#1B1B1B"/>
    <SolidColorBrush x:Key="TooltipBorder"    Color="#D0D0D0"/>

    <!-- Fullscreen / overlay buttons -->
    <SolidColorBrush x:Key="OverlayBtnBg"     Color="#AA000000"/>
    <SolidColorBrush x:Key="OverlayBtnBorder" Color="#55FFFFFF"/>
    <SolidColorBrush x:Key="OverlayBtnFg"     Color="#FFFFFF"/>

</ResourceDictionary>
