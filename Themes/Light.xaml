<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Window / chrome ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="WindowBg"          Color="#F3F3F3"/>
    <SolidColorBrush x:Key="VideoAreaBg"       Color="#ECECEC"/>

    <!-- ── Toolbar bars ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ToolbarBg"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ToolbarBorder"     Color="#D9D9D9"/>

    <!-- ── Buttons ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BtnBg"             Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BtnBorder"         Color="#C8C8C8"/>
    <SolidColorBrush x:Key="BtnFg"             Color="#1F1F1F"/>
    <SolidColorBrush x:Key="BtnHover"          Color="#F0F0F0"/>
    <SolidColorBrush x:Key="BtnPress"          Color="#E5E5E5"/>

    <!-- Accent button -->
    <SolidColorBrush x:Key="BtnConnectBg"      Color="#0078D4"/>
    <SolidColorBrush x:Key="BtnConnectBorder"  Color="#006CBE"/>

    <!-- Danger button -->
    <SolidColorBrush x:Key="BtnDangerBg"       Color="#FDE7E9"/>
    <SolidColorBrush x:Key="BtnDangerBorder"   Color="#D13438"/>
    <SolidColorBrush x:Key="BtnDangerFg"       Color="#A4262C"/>

    <!-- ── Inputs ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="InputBg"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputFg"           Color="#1F1F1F"/>
    <SolidColorBrush x:Key="InputBorder"       Color="#C8C8C8"/>
    <SolidColorBrush x:Key="InputCaret"        Color="#1F1F1F"/>

    <!-- ── Labels / separators ───────────────────────────────────── -->
    <SolidColorBrush x:Key="LabelFg"           Color="#444444"/>
    <SolidColorBrush x:Key="SeparatorBg"       Color="#D9D9D9"/>

    <!-- ── Status bar ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="StatusBarBg"       Color="#F7F7F7"/>
    <SolidColorBrush x:Key="StatusBarBorder"   Color="#D9D9D9"/>
    <SolidColorBrush x:Key="StatusFg"          Color="#444444"/>
    <SolidColorBrush x:Key="StatusDotOff"      Color="#A0A0A0"/>

    <!-- ── Video screen panels ───────────────────────────────────── -->
    <SolidColorBrush x:Key="ScreenBg"          Color="#000000"/>
    <SolidColorBrush x:Key="ScreenBorder"      Color="#C8C8C8"/>
    <SolidColorBrush x:Key="ScreenDivider"     Color="#E5E5E5"/>
    <SolidColorBrush x:Key="ScreenLabelFg"     Color="#666666"/>

    <!-- ── Stream badges ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BadgeWaiting"      Color="#A0A0A0"/>
    <SolidColorBrush x:Key="FpsFg"             Color="#666666"/>

    <!-- ── Side panel / log ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="SidePanelBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidePanelBorder"   Color="#D9D9D9"/>
    <SolidColorBrush x:Key="LogHeaderBg"       Color="#F3F3F3"/>
    <SolidColorBrush x:Key="LogHeaderFg"       Color="#444444"/>
    <SolidColorBrush x:Key="LogBg"             Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LogFg"             Color="#107C10"/>

    <!-- ── Speedrun timer ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TimerBg"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TimerBorder"       Color="#D9D9D9"/>
    <SolidColorBrush x:Key="TimerFg"           Color="#8A6D00"/>

    <!-- ── VU meter ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="VuBg"              Color="#ECECEC"/>
    <SolidColorBrush x:Key="VuBorder"          Color="#D9D9D9"/>

    <!-- ── ComboBox dropdown item colours ───────────────────────── -->
    <SolidColorBrush x:Key="ComboItemFg"       Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ComboItemBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboItemHoverBg"  Color="#E5F3FF"/>
    <SolidColorBrush x:Key="ComboItemHoverFg"  Color="#000000"/>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background"  Value="{DynamicResource ComboItemBg}"/>
        <Setter Property="Foreground"  Value="{DynamicResource ComboItemFg}"/>
        <Setter Property="Padding"     Value="7,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ComboItemHoverBg}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ComboItemHoverFg}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ComboItemHoverBg}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ComboItemHoverFg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>