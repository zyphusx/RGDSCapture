<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ╔══════════════════════════════════════════════════════════════╗
         ║  RGDSCapture — Light Theme (Windows 11 Fluent)              ║
         ╚══════════════════════════════════════════════════════════════╝ -->

    <SolidColorBrush x:Key="WindowBg"           Color="#F3F3F3"/>
    <SolidColorBrush x:Key="Layer1Bg"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Layer2Bg"           Color="#F9F9F9"/>
    <SolidColorBrush x:Key="Layer3Bg"           Color="#F3F3F3"/>
    <SolidColorBrush x:Key="VideoAreaBg"        Color="#E5E5E5"/>

    <SolidColorBrush x:Key="ToolbarBg"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ToolbarBorder"      Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SeparatorBg"        Color="#D8D8D8"/>

    <SolidColorBrush x:Key="AccentBg"           Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHover"        Color="#1A86DC"/>
    <SolidColorBrush x:Key="AccentPress"        Color="#006CBE"/>
    <SolidColorBrush x:Key="AccentFg"           Color="#FFFFFF"/>

    <SolidColorBrush x:Key="BtnBg"              Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BtnBorder"          Color="#D1D1D1"/>
    <SolidColorBrush x:Key="BtnFg"              Color="#1A1A1A"/>
    <SolidColorBrush x:Key="BtnHover"           Color="#F5F5F5"/>
    <SolidColorBrush x:Key="BtnPress"           Color="#EBEBEB"/>
    <SolidColorBrush x:Key="BtnConnectBg"       Color="#0078D4"/>
    <SolidColorBrush x:Key="BtnConnectBorder"   Color="#0078D4"/>
    <SolidColorBrush x:Key="BtnConnectFg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BtnDangerBg"        Color="#FEF0EF"/>
    <SolidColorBrush x:Key="BtnDangerBorder"    Color="#F0BCBB"/>
    <SolidColorBrush x:Key="BtnDangerFg"        Color="#BC2F32"/>
    <SolidColorBrush x:Key="BtnDangerHover"     Color="#FAE3E2"/>

    <SolidColorBrush x:Key="InputBg"            Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputFg"            Color="#1A1A1A"/>
    <SolidColorBrush x:Key="InputBorder"        Color="#D1D1D1"/>
    <SolidColorBrush x:Key="InputBorderFocus"   Color="#0078D4"/>
    <SolidColorBrush x:Key="InputCaret"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="InputPlaceholder"   Color="#A0A0A0"/>

    <SolidColorBrush x:Key="TextPrimary"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextSecondary"      Color="#606060"/>
    <SolidColorBrush x:Key="TextDisabled"       Color="#B0B0B0"/>
    <SolidColorBrush x:Key="LabelFg"            Color="#484848"/>

    <SolidColorBrush x:Key="StatusBarBg"        Color="#F0F0F0"/>
    <SolidColorBrush x:Key="StatusBarBorder"    Color="#E0E0E0"/>
    <SolidColorBrush x:Key="StatusFg"           Color="#606060"/>
    <SolidColorBrush x:Key="StatusDotOff"       Color="#B0B0B0"/>

    <SolidColorBrush x:Key="ScreenBg"           Color="#0A0A0A"/>
    <SolidColorBrush x:Key="ScreenBorder"       Color="#C8C8C8"/>
    <SolidColorBrush x:Key="ScreenDivider"      Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ScreenLabelFg"      Color="#B0B0B0"/>

    <SolidColorBrush x:Key="BadgeWaiting"       Color="#A0A0A0"/>
    <SolidColorBrush x:Key="FpsFg"             Color="#808080"/>

    <SolidColorBrush x:Key="SidePanelBg"        Color="#FAFAFA"/>
    <SolidColorBrush x:Key="SidePanelBorder"    Color="#E0E0E0"/>
    <SolidColorBrush x:Key="LogHeaderBg"        Color="#F3F3F3"/>
    <SolidColorBrush x:Key="LogHeaderFg"        Color="#606060"/>
    <SolidColorBrush x:Key="LogBg"              Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LogFg"              Color="#107C10"/>

    <SolidColorBrush x:Key="TimerBg"            Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TimerBorder"        Color="#D8D8D8"/>
    <SolidColorBrush x:Key="TimerFg"            Color="#7A5A00"/>

    <SolidColorBrush x:Key="VuBg"              Color="#E8E8E8"/>
    <SolidColorBrush x:Key="VuBorder"          Color="#D1D1D1"/>

    <SolidColorBrush x:Key="MenuBg"             Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MenuFg"             Color="#1A1A1A"/>
    <SolidColorBrush x:Key="MenuBorder"         Color="#E0E0E0"/>
    <SolidColorBrush x:Key="MenuItemHover"      Color="#F3F3F3"/>
    <SolidColorBrush x:Key="MenuItemPress"      Color="#E8E8E8"/>
    <SolidColorBrush x:Key="MenuSeparator"      Color="#E0E0E0"/>

    <SolidColorBrush x:Key="FocusRing"          Color="#0078D4"/>

    <SolidColorBrush x:Key="ComboItemFg"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ComboItemBg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboItemHoverBg"   Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ComboItemHoverFg"   Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ComboPopupBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboPopupBorder"   Color="#D1D1D1"/>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background"   Value="{DynamicResource ComboItemBg}"/>
        <Setter Property="Foreground"   Value="{DynamicResource ComboItemFg}"/>
        <Setter Property="Padding"      Value="10,6"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" CornerRadius="4"
                            Margin="3,1">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource ComboItemHoverBg}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ComboItemHoverFg}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource AccentBg}"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
